package linkedlistpractice.com;
//creating a linkedlist
public class Node {
    int data;
    Node next;
    public Node(int data,Node next){
        this.data=data;
        this.next=next;
    }
    public Node(int data){
        this.next=null;
        this.data=data;
    }
    public static void main(String[] args) {
        int arr[]={1,2,3,4};
        Node head=new Node(arr[0]);
        System.out.println(head.data);
    }
}
