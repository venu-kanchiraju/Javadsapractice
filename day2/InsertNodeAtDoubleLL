package linkedlistpractice.com;
//Insert a node at the end of the double linkedlist
public class Node7 {
    int data;
    Node7 next;
    Node7 back;
    public Node7(int data,Node7 next,Node7 back){
        this.data=data;
       this.next=next;
       this.back=back;
    }
    public Node7(int data){
        this.data=data;
        this.next=null;
        this.back=null;
    }
    public static Node7 insertNodeAtEnd(Node7 head,int val){
        Node7 newNode=new Node7(val);
        if(head==null){
            return newNode;
        }
        Node7 temp=head;
        while (temp.next!=null){
            temp=temp.next;
        }
        temp.next=newNode;
        newNode.back=temp;
        return head;
    }
    public static void printll(Node7 head){
        while (head!=null){
            System.out.print(head.data+"->");
            head=head.next;
        }
    }
    public static Node7 convertArrTo2Dll(int arr[]){
        Node7 head=new Node7(arr[0]);
        Node7 prev=head;
        for (int i=1;i<arr.length;i++){
            Node7 temp=new Node7(arr[i],null,prev);
            prev.next=temp;
            prev=temp;
        }
        return head;
    }
    public static void main(String[] args) {
        int arr[]={1,2,3,4};
        Node7 head=convertArrTo2Dll(arr);
        int val=5;
        head=insertNodeAtEnd(head,val);
        printll(head);
    }
}
--------output-------------
1->2->3->4->5->
