package Arraypractice.com;
//find the min
public class FindMin {
    public static void main(String[] args) {

        int arr[]={4,2,31,44,5};
        int min=arr[0];
        for (int i:arr){
            if(i<min){
                min=i;
            }
        }
        System.out.println(min);
    }
}
