package Arraypractice.com;

public class CountEvenNums {
    public static void main(String[] args) {
        int count_even = 0;
        int arr[] = {1, 2, 3, 4, 5, 6};
        for (int a : arr) {
            if (a % 2 == 0) {
                count_even++;
            }
        }
        System.out.println("The even numbers is: "+count_even);
    }
}

