package Arraypractice.com;

public class Count_Odd {
    public static void main(String[] args) {
        int count_odd = 0;
        int arr[] = {1, 2, 3, 4, 5, 6};
        for (int a : arr) {
            if (a % 2 ==1) {
                count_odd++;
            }
        }
        System.out.println("The odd numbers is: "+count_odd);
    }
}

