package Arraypractice.com;

import java.util.Arrays;

//find max element in an array
public class FindMax {
    public static void main(String[] args) {
        int arr[]={1,2,3,4,5};
        int max=0;
        for (int i:arr){
            if(i>max){
                max=i;
            }
        }
        System.out.println(max);
    }
}
-------output-------
5
